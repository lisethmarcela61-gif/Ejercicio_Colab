class carro:
  def __init__(self):
    self._placa = ""
    self._modelo = ""
    self._fecha_entrada = ""
    self._hora_entrada = ""

  def registrar_entrada(self):
    info = f"entrada vehículo {self._fecha_entrada}"
    info = info + f" hora {self._hora_entrada}"
    return info

  def get_placa(self):
    return self._placa

  def set_placa(self, nuevo_dato):
    self._placa = nuevo_dato

class carro_publico(carro):

  def __init__(self, dato_matricula):
    super().__init__()
    self._matricula = dato_matricula

  def get_matricula(self):
    return self._matricula

  def set_matricula(self, nuevo_dato):
    self._matricula = nuevo_dato

  def ver_info(self):
    info = super().get_placa()
    info = info + self._matricula
    return info


def tomar_primer_numero():
  print("Escribe el primer número entero (para verificar si es múltiplo):")
  num1 = int(input())
  return num1

def tomar_segundo_numero():
  print("Escribe el segundo número entero (el posible divisor/factor):")
  num2 = int(input())
  return num2

def es_multiplo(num1, num2):
  if num2 == 0:
    return "No se puede determinar si un número es múltiplo de cero."
  elif num1 % num2 == 0:
    return str(num1) + " es múltiplo de " + str(num2) + "."
  else:
    return str(num1) + " no es múltiplo de " + str(num2) + "."

def imprimir_resultado(mensaje):
  print(mensaje)

dato_num1 = tomar_primer_numero()
dato_num2 = tomar_segundo_numero()
resultado_multiplo = es_multiplo(dato_num1, dato_num2)
imprimir_resultado(resultado_multiplo)


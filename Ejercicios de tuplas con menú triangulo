""" ¿que es la tupla ?
Una tupla es una estructura de datos en Python que sirve para guardar varios valores en una sola variable.
Los datos de la tupla se escriben entre paréntesis ( ) y se separan por comas.
Una característica importante es que las tuplas son inmutables, es decir, no se pueden modificar después de crearse.

¿cómo se estructura las tuplas ?
Las tuplas en Python se estructuran colocando los datos dentro de paréntesis ( ) y separados por comas.

¿como se modifica la información dentro las tuplas ?
Las tuplas no se pueden modificar directamente porque son inmutables.
Esto significa que una vez creada la tupla, sus valores no se pueden cambiar, agregar ni eliminar.

¿cual es la ventaja de usar una tupla y cual es la función ?
Una de las principales ventajas de las tuplas en Python es que los datos no se pueden modificar. Esto ayuda a proteger la información para que no se cambie por error.

Ventaja: los datos están protegidos porque no se pueden modificar.

Función: almacenar varios valores juntos de forma ordenada."""

"""
hacer el ejercicio de la tienda de venta de triángulos donde los requerimientos son:
tener una clase triangulo
tener un constructor que inicialice la información del triángulo
que la información del triangulo se almacene en la siguiente estructura db_info = [ ( lado , altura , área ) , ( lado , altura , área ) ]
incluir menu de ventas y almacenamiento de datos (crear, modificar, guardar y buscar)
"""


#zona clases
class Triangulo:
    def __init__(self):
        self.db_info = []

    def tomar_base(self):
        # Usamos float por si el usuario mete decimales
        base = float(input("Ingrese la base del triangulo: "))
        return base

    def tomar_altura(self):
        altura = float(input("Digite la altura del triangulo: "))
        return altura

    def calcular(self, base, altura):
        area = (base * altura) / 2
        return area

    def menu(self):
        while True:
            print("\n--- SISTEMA TRIANGULOS ---")
            print("1. Registrar nuevo triangulo")
            print("2. Ver todos los registros")
            print("3. Modificar un registro")
            print("4. Buscar por base")
            print("5. Salir")

            op = int(input("Seleccione una opcion: "))

            match op:
                case 1:
                    b = self.tomar_base()
                    h = self.tomar_altura()
                    a = self.calcular(b, h)

                    tupla = (b, h, a)
                    self.db_info.append(tupla)
                    print("GUARDADO")

                case 2:
                    print("\nLISTA DE REGISTROS")
                    for i in range(len(self.db_info)):
                        t = self.db_info[i]
                        print(f"ID {i}: Base {t[0]}, Altura {t[1]}, Area {t[2]}")

                case 3:
                    pos = int(input("¿Que ID desea modificar?: "))
                    if 0 <= pos < len(self.db_info):
                        n_b = self.tomar_base()
                        n_h = self.tomar_altura()
                        # Le pasamos los nuevos datos al calcular
                        n_a = self.calcular(n_b, n_h)
                        self.db_info[pos] = (n_b, n_h, n_a)
                        print("Actualizado.")
                    else:
                        print("Ese ID no existe.")

                case 4:
                    buscar_lado = float(input("Digite la base que desea buscar: "))
                    encontrado = False

                    for i in range(len(self.db_info)):
                        t = self.db_info[i]
                        if t[0] == buscar_lado:
                            print(f"Encontrado ID {i}: Base {t[0]}, Altura {t[1]}, Área {t[2]}")
                            encontrado = True

                    if not encontrado:
                        print("No hay ningún triángulo con esa medida de base.")

                case 5:
                    print("Saliendo del sistema...")
                    break

# 1. Creamos el objeto con paréntesis ()
mi_triangulo = Triangulo()
# 2. Llamamos al método con paréntesis ()
mi_triangulo.menu()

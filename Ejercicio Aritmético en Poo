class MayorDeDos:
  def __init__(self):
    self.numero1 = " "
    self.numero2 = " "
    self.mayor = " "

  def tomar_numero1(self):
    self.numero1 = int(input("Digite el primer número: "))

  def tomar_numero2(self):
    self.numero2 = int(input("Digite el segundo número: "))

  def calcular_mayor(self):
    self.mayor = (self.numero1 + self.numero2 + abs(self.numero1 - self.numero2)) // 2

  def ver_resultado(self):
    info = f"El mayor de los dos números es: {self.mayor}"
    return info

#ZONA DE CODIGO PRINCIPAL

# crear el objeto

obj_mayor = MayorDeDos()
obj_mayor.tomar_numero1()
obj_mayor.tomar_numero2()
obj_mayor.calcular_mayor()

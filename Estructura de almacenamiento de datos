class lista_cliente:
  def __init__(self):
    self.base_datos = [] # Initialize base_datos correctly
    print("Base de datos de clientes inicializada.")

  def guardar_opcio(self):
    while True:
      print("-----MENU-----")
      print("1. Guardar un cliente")
      print("2. Guardar varios clientes")
      print("3. Insertar cliente en posición determinada")
      print("4. Eliminar cliente")
      print("5. Buscar cliente y eliminar el cliente")
      print("6. Buscar cliente e imprimir el cliente")
      print("7. Buscar cliente")
      print("8. Contar las veces que se repite el cliente")
      print("9. Ordenar lista de menor a mayor")
      print("10. Ordenar lista de mayor a menor")
      print("11. Ver la base de datos")
      print("12. Salir del sistema")

      try:
        cont = int(input("Digite la opcion: "))
      except ValueError:
        print("Por favor, ingrese un número válido.")
        continue

      if cont == 1:
        nombre_cliente = input("Escriba el nombre del cliente: ")
        self.base_datos.append(nombre_cliente)
        print(f"Cliente '{nombre_cliente}' guardado.")
      elif cont == 2:
        try:
          cantidad_clientes = int(input("Escriba la cantidad de clientes a guardar: "))
          for _ in range(cantidad_clientes):
            nombre_cliente = input("Escriba el nombre del cliente: ")
            self.base_datos.append(nombre_cliente)
          print(f"{cantidad_clientes} clientes guardados.")
        except ValueError:
          print("Por favor, ingrese un número válido para la cantidad de clientes.")
      elif cont == 3:
        try:
          posicion_cliente = int(input("Escriba la posición a donde lo quiere insertar (índice): "))
          nombre_cliente = input("Escriba el nombre del cliente: ")
          if 0 <= posicion_cliente <= len(self.base_datos):
            self.base_datos.insert(posicion_cliente, nombre_cliente)
            print(f"Cliente '{nombre_cliente}' insertado en la posición {posicion_cliente}.")
          else:
            print("La posición ingresada está fuera de rango.")
        except ValueError:
          print("Por favor, ingrese un número válido para la posición.")
      elif cont == 4:
        nombre_cliente = input("Escriba el nombre del cliente que desee eliminar: ")
        if nombre_cliente in self.base_datos:
          self.base_datos.remove(nombre_cliente)
          print(f"Cliente '{nombre_cliente}' eliminado.")
        else:
          print(f"El cliente '{nombre_cliente}' no se encontró en la base de datos.")
      elif cont == 5:
        nombre_cliente = input("Escriba el nombre del cliente que desee buscar y eliminar: ")
        if nombre_cliente in self.base_datos:
          posicion_cliente = self.base_datos.index(nombre_cliente)
          self.base_datos.pop(posicion_cliente)
          print(f"Cliente '{nombre_cliente}' encontrado y eliminado de la posición {posicion_cliente}.")
        else:
          print(f"El cliente '{nombre_cliente}' no se encontró en la base de datos.")
      elif cont == 6:
        nombre_cliente = input("Escriba el nombre del cliente que desee buscar e imprimirlo: ")
        if nombre_cliente in self.base_datos:
          posiciones = [i for i, x in enumerate(self.base_datos) if x == nombre_cliente]
          print(f"El cliente '{nombre_cliente}' se encuentra en las posiciones: {posiciones}")
        else:
          print(f"El cliente '{nombre_cliente}' no se encontró en la base de datos.")
      elif cont == 7:
        nombre_cliente = input("Escriba el nombre del cliente que desee buscar: ")
        if nombre_cliente in self.base_datos:
          posiciones = [i for i, x in enumerate(self.base_datos) if x == nombre_cliente]
          print(f"El cliente '{nombre_cliente}' se encuentra en las posiciones: {posiciones}")
        else:
          print(f"El cliente '{nombre_cliente}' no se encontró en la base de datos.")
      elif cont == 8:
        nombre_cliente = input("Digite el nombre del cliente a buscar para contar: ")
        num = self.base_datos.count(nombre_cliente)
        print(f"El cliente '{nombre_cliente}' se repite en la lista: {num} veces.")
      elif cont == 9:
        if self.base_datos:
          self.base_datos.sort()
          print(f"Orden de menor a mayor: {self.base_datos}")
        else:
          print("La base de datos está vacía.")
      elif cont == 10:
        if self.base_datos:
          self.base_datos.sort(reverse=True)
          print(f"Orden de mayor a menor: {self.base_datos}")
        else:
          print("La base de datos está vacía.")
      elif cont == 11:
        if self.base_datos:
          print("--- Base de Datos de Clientes ---")
          for i, nombre in enumerate(self.base_datos):
            print(f"{i}. {nombre}")
          print("-----------------------------------")
        else:
          print("La base de datos está vacía.")
      elif cont == 12:
        print("Saliendo del sistema.")
        break
      else:
        print("Opción no válida. Por favor, intente de nuevo.")

